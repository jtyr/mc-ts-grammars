/build/
/release/

# Ignore everything in grammar src/ directories, then whitelist
# only the files needed for building grammars.
grammars/*/src/*

# --- First level: keep essential files ---
!grammars/*/src/grammar.js
!grammars/*/src/package.json
!grammars/*/src/LICENSE*

# --- Keep directories that may contain JS deps or C sources ---
!grammars/*/src/*/

# --- Second-level directories: ignore contents, whitelist needed files ---
grammars/*/src/*/*

# Keep C/C++ source and header files in any subdirectory (src/src/, etc.)
!grammars/*/src/*/*.c
!grammars/*/src/*/*.cc
!grammars/*/src/*/*.h

# Keep JS/JSON files for grammar.js dependencies (lib/, common/, grammar/, etc.)
!grammars/*/src/*/*.js
!grammars/*/src/*/*.json

# Keep upstream query files and LICENSE in queries/
!grammars/*/src/queries/*.scm
!grammars/*/src/queries/LICENSE*

# Descend one more level for subdirectories with C/H files
!grammars/*/src/*/*/
grammars/*/src/*/*/*
!grammars/*/src/*/*/*.c
!grammars/*/src/*/*/*.h
!grammars/*/src/*/*/*.js

# --- Exclude language bindings and build placeholders ---
grammars/*/src/src/binding.c
grammars/*/src/src/binding.cc
grammars/*/src/src/dummy.c

# --- Always ignore generated files ---
grammars/*/src/src/parser.c
grammars/*/src/src/grammar.json
grammars/*/src/src/node-types.json
grammars/*/src/src/tree_sitter/

# --- Always ignore npm artifacts ---
grammars/*/src/**/node_modules
grammars/*/src/**/node_modules/**
grammars/*/src/**/package-lock.json
